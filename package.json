{
  "name": "ai",
  "version": "1.0.0",
  "description": "OpenSphere subShell — AI. Angular 22 + Clarity 18, exported as Angular Element <osp-ai-shell>. Standalone project: `ng build` → dist served by server.js (generic K8s proxy + WS exec).",
  "private": true,
  "scripts": {
    "build": "ng build --configuration production",
    "start": "ng serve",
    "serve:backend": "node server.js",
    "test": "npm run test:contracts && npm run test:ui",
    "test:contracts": "npm run test:rbac && npm run test:support-services && node scripts/verify-constitution-0003.js",
    "test:ui": "npm run build && npm run test:browser-support-services",
    "test:browser-support-services": "node scripts/verify-support-services-browser.js",
    "test:live-browser-support-services": "node scripts/verify-live-support-services-browser.js",
    "test:live-support-services": "powershell -ExecutionPolicy Bypass -File scripts/verify-live-support-services.ps1",
    "release:promote-images": "powershell -ExecutionPolicy Bypass -File scripts/promote-oah-images.ps1",
    "release:sign-manifest": "node scripts/sign-manifest.cjs",
    "release:login-registry": "powershell -ExecutionPolicy Bypass -File scripts/login-release-registry.ps1",
    "test:product-flow": "powershell -ExecutionPolicy Bypass -File scripts/verify-oah-product-flow.ps1",
    "test:rbac": "node scripts/verify-rbac.js",
    "test:release": "powershell -ExecutionPolicy Bypass -File scripts/verify-oah-release.ps1",
    "test:production-preflight": "powershell -ExecutionPolicy Bypass -File scripts/verify-production-preflight.ps1",
    "test:support-services": "node scripts/verify-support-services.js",
    "test:upstream-parity": "powershell -ExecutionPolicy Bypass -File scripts/verify-upstream-parity.ps1"
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/elements": "^22.0.1",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@carbon/icons": "^11.82.0",
    "@cds/core": "^6.17.0",
    "@clr/angular": "^18.2.0",
    "@clr/ui": "^18.2.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "js-yaml": "^4.2.0",
    "pg": "^8.13.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "ws": "^8.18.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "~6.0.0"
  }
}
